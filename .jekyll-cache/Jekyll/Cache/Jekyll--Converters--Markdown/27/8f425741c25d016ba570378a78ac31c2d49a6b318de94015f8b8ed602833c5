<h4 id="playercontroller">­ЪЊюPlayerController</h4>

<div class="language-c# highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="kt">bool</span> <span class="n">_stopSkill</span> <span class="p">=</span> <span class="k">false</span><span class="p">;</span>

	<span class="k">public</span> <span class="n">PlayerState</span> <span class="n">State</span> <span class="c1">// StateвЦ╝ ВЋавІѕвЕћВЮ┤ВЁўЖ│╝ Ж░ЎВЮ┤ Ж┤ђвдг</span>
	<span class="p">{</span>
		<span class="k">get</span> <span class="p">{</span> <span class="k">return</span> <span class="n">_state</span><span class="p">;</span> <span class="p">}</span>
		<span class="k">set</span>
		<span class="p">{</span>
			<span class="n">_state</span> <span class="p">=</span> <span class="k">value</span><span class="p">;</span> <span class="c1">// ВЃЂьЃю ВёИьїЁ</span>

            <span class="c1">// ВЋавІѕвЕћВЮ┤ВЁў ВъгВЃЮ</span>
			<span class="n">Animator</span> <span class="n">anim</span> <span class="p">=</span> <span class="n">GetComponent</span><span class="p">&lt;</span><span class="n">Animator</span><span class="p">&gt;();</span>
			<span class="k">switch</span> <span class="p">(</span><span class="n">_state</span><span class="p">)</span>
			<span class="p">{</span>
				<span class="k">case</span> <span class="n">PlayerState</span><span class="p">.</span><span class="n">Die</span><span class="p">:</span>
					<span class="k">break</span><span class="p">;</span>
				<span class="k">case</span> <span class="n">PlayerState</span><span class="p">.</span><span class="n">Idle</span><span class="p">:</span>
					<span class="n">anim</span><span class="p">.</span><span class="nf">CrossFade</span><span class="p">(</span><span class="s">"WAIT"</span><span class="p">,</span> <span class="m">0.1f</span><span class="p">);</span>
					<span class="k">break</span><span class="p">;</span>
				<span class="k">case</span> <span class="n">PlayerState</span><span class="p">.</span><span class="n">Moving</span><span class="p">:</span>
					<span class="n">anim</span><span class="p">.</span><span class="nf">CrossFade</span><span class="p">(</span><span class="s">"RUN"</span><span class="p">,</span> <span class="m">0.1f</span><span class="p">);</span>
					<span class="k">break</span><span class="p">;</span>
				<span class="k">case</span> <span class="n">PlayerState</span><span class="p">.</span><span class="n">Skill</span><span class="p">:</span>
					<span class="n">anim</span><span class="p">.</span><span class="nf">CrossFade</span><span class="p">(</span><span class="s">"ATTACK"</span><span class="p">,</span> <span class="m">0.1f</span><span class="p">,</span> <span class="p">-</span><span class="m">1</span><span class="p">,</span> <span class="m">0f</span><span class="p">);</span>
					<span class="k">break</span><span class="p">;</span>
			<span class="p">}</span>
		<span class="p">}</span>
	<span class="p">}</span>
</code></pre></div></div>

<ul>
  <li><code class="language-plaintext highlighter-rouge">_stopSkill</code>ВЮ┤ trueвЕ┤ Ж│хЖ▓ЕВЮё вЕѕВХћЖ▓ї ьЋа Ж▓ЃВЮ┤вІц.</li>
  <li><code class="language-plaintext highlighter-rouge">State</code>ьћёвАюьЇ╝ьІ░ ­ЪЉЅ ВЃЂьЃю ВёИьїЁЖ│╝ ВЋавІѕвЕћВЮ┤ВЁўВЮђ Ж▒░ВЮў ьЋю ВёИьіИ вДѕвЃЦ вХЎВќ┤ ВъѕЖ▓ї вљўв»ђвАю ВЋёВўѕ ВЃЂьЃю ьћёвАюьЇ╝ьІ░вЦ╝ вДївЊцВќ┤Вёю ВЃЂьЃю ВёИьїЁ ВЋѕВЌљ ВЋавІѕвЕћВЮ┤ВЁў ВъгВЃЮ ВйћвЊювЦ╝ вёБВќ┤ вЉўВЮ┤ ьЋеЖ╗ў вХЎВќ┤вІцвІѕЖ▓ївЂћ ьЋювІц.
    <ul>
      <li>ВЮ┤вЪ░Ж▓ЃвЈё ЖхЅВъЦьъѕ ВюаВџЕьЋа ВйћвћЕ ВіцьѓгВЮИ Ж▓Ѓ Ж░ЎвІц. ВЃЂьЃю ВёИьїЁ вњцВЌљвіћ ьЋГВЃЂ ВЋавІѕвЕћВЮ┤ВЁў ВъгВЃЮВЮ┤ вњцвћ░вЦИвІцвЕ┤ ВЃЂьЃювЦ╝ ьћёвАюьЇ╝ьІ░вАю вДївЊцВќ┤Вёю ВёИьїЁВІю ВЮ┤Вќ┤Вёю ВЋавІѕвЕћВЮ┤ВЁўВЮ┤ ВъгВЃЮвља Вѕў ВъѕвЈёвАЮ ьЋўвіћ Ж▓Ѓ!</li>
    </ul>
  </li>
  <li>ВЋавІѕвЕћВЮ┤ВЁў ВъгВЃЮ
    <ul>
      <li><em>anim.CrossFade</em>
        <ul>
          <li><em>anim.Play</em> вЦ╝ вХђвЊювЪйЖ▓ї ьЋўвіћ Ж▓ЃВЮ┤вЮ╝Ж│а в│┤вЕ┤ вљювІц. вХђвЊювЪйЖ│а ВъљВЌ░ВіцвЪйЖ▓ї вИћваївћЕвљўвЊ» ВЋавІѕвЕћВЮ┤ВЁўВЮ┤ ВъгВЃЮвљювІц.
            <ul>
              <li><em>anim.Play</em>вЦ╝ ВѓгВџЕьЋўвЕ┤ ВъгВЃЮьЋа ВЋавІѕвЕћВЮ┤ВЁў ьЂ┤вдйВЮ┤ в░ћвђћ вЋї вџЮвџЮ вЂіЖИ░вЊ»ВЮ┤ в░ћвђїВќ┤ вХђВъљВЌ░ВіцвЪйвІц. <em>anim.CrossFade</em> віћ ВЋавІѕвЕћВЮ┤ВЁўВЮ┤ ВЋёВБ╝ ВъљВЌ░ВіцвЪйЖ▓ї в░ћвђїЖ▓ї вљювІц.</li>
            </ul>
          </li>
          <li>В▓Ф в▓ѕВДИ ВЮИВѕў : ВъгВЃЮьЋа ьЂ┤вдй ВЮ┤вдё</li>
          <li>вЉљ в▓ѕВДИ ВЮИВѕў : ВДђВЌ░ ВІюЖ░ё (вІцВЮї ВЋавІѕвЕћВЮ┤ВЁўВю╝вАю в░ћвђївіћвЇ░ Ж▒Ивдгвіћ fade ВІюЖ░ё)
            <ul>
              <li>0.1f вЮ╝вЕ┤ в░ћвђћ ВЋавІѕвЕћВЮ┤ВЁўВЮў 10 %віћ вХђвЊювЪйЖ▓ї ВЋавІѕвЕћВЮ┤ВЁўВЮ┤ ВЮ┤Вќ┤ВДђвіћвЇ░ ВЊ┤вІц.</li>
            </ul>
          </li>
          <li>ВёИ в▓ѕВДИ ВЮИВѕў : layer. ВЋавІѕвЕћВЮ┤ВЁў ваѕВЮ┤Вќ┤</li>
          <li>вёц в▓ѕВДИ ВЮИВѕў(normalizedTimeOffset) : ВЋавІѕвЕћВЮ┤ВЁўВЮў ВъгВЃЮ ВІюВъЉ ВІюВаљ (0~1 в╣ёВюе)
            <ul>
              <li>0.0f вАю ВёИьїЁьЋўвЕ┤ вІцВІю В▓ўВЮїВю╝вАю вЈїВЋёЖ░ђ ВъгВЃЮьЋювІц.</li>
              <li>ьЂ┤вдйВЮў <code class="language-plaintext highlighter-rouge">Loop Time</code>ВЮ┤ В▓┤ьЂгвљўВќ┤ ВъѕВДђ ВЋівЇћвЮ╝вЈё ВЮ┤ваЄЖ▓ї ВйћвЊювАю в░ўв│х ВъгВЃЮ ВІюьѓг Вѕў ВъѕвІц.</li>
            </ul>
          </li>
        </ul>
      </li>
      <li>ьїївЮ╝в»Иьё░ в░Ј TranssitionЖ│╝ ВА░Ж▒┤ВЮё ВѓгВџЕьЋўВДђ ВЋіЖ│а в░ћвАю ВЋавІѕвЕћВЮ┤ВЁўВЮё ВъгВЃЮ ВІюьѓе ВЮ┤Вюа
        <ul>
          <li>Ж│хЖ▓Е ьїївЮ╝в»Иьё░Ж░ђ false ВЮ┤вЕ┤ Ж▒ИВЮё ВѕўвЈё ВъѕЖ│а вЏИ ВѕўвЈё ВъѕвІц. вЉљ ВЃЂьЃюЖ░ђ вІц Ж░ђвіЦьЋўв»ђвАю вўљ ВЋавДцьЋ┤ВаИВёю ВЮ┤вЦ╝ Жхгв│ёьЋа Віцьћ╝вЊю ьїївЮ╝в»Иьё░Ж░ђ вўљ ьЋёВџћьЋю Ж▓ЃВЮ┤вІц. ВЮ┤вЪ░ВІЮВю╝вАю ьїївЮ╝в»Иьё░Ж░ђ вДјВЋёВДђвЕ┤ в│хВъАьЋўвІц.</li>
          <li>В░евЮ╝вдг ВЮ┤ваЄЖ▓ї ьїївЮ╝в»Иьё░вЦ╝ Ж░ђВДђЖ│а ьЋўвіћ Transition ВА░Ж▒┤Вю╝вАю ВЋавІѕвЕћВЮ┤ВЁўВЮё ВъгВЃЮ ВІюьѓцВДђ ВЋіЖ│а ЖиИвЃЦ Play ВІюьѓцвЊ» ВЋавІѕвЕћВЮ┤ВЁў ьЂ┤вдйВЮё ВъгВЃЮ вћ▒ ВІюьѓцвіћЖ▓ї вЇћ вѓўВЮё Вѕў ВъѕвІц!
            <ul>
              <li>вХђвЊювЪйЖ▓ї Play ьЋўвіћ CrossFade ВѓгВџЕ.</li>
            </ul>
          </li>
        </ul>
      </li>
    </ul>
  </li>
</ul>

