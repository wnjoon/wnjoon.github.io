<h3 id="playercontroller-1">­ЪЊюPlayerController</h3>

<div class="language-c# highlighter-rouge"><div class="highlight"><pre class="highlight"><code>	<span class="k">void</span> <span class="nf">UpdateMoving</span><span class="p">()</span>
	<span class="p">{</span>
		<span class="c1">// вфгВіцьё░Ж░ђ вѓ┤ ВѓгВаЋЖ▒░вдгв│┤вІц Ж░ђЖ╣їВџ░вЕ┤ Ж│хЖ▓Е</span>
