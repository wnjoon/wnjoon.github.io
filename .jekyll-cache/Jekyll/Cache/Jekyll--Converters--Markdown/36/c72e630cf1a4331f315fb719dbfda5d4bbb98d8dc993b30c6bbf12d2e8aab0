        <span class="n">pointManager</span><span class="p">.</span><span class="n">point</span> <span class="p">=</span> <span class="p">-</span><span class="m">100</span><span class="p">;</span>
        <span class="n">Debug</span><span class="p">.</span><span class="nf">Log</span><span class="p">(</span><span class="s">"현재 점수 "</span> <span class="p">+</span> <span class="n">pointManager</span><span class="p">.</span><span class="n">point</span><span class="p">);</span>
