    <span class="k">public</span> <span class="kt">int</span><span class="p">[]</span> <span class="n">scores</span> <span class="p">=</span> <span class="k">new</span> <span class="kt">int</span><span class="p">[</span><span class="m">10</span><span class="p">];</span> <span class="c1">// 배열 ✨</span>

