<span class="k">public</span> <span class="k">class</span> <span class="nc">ItemBox</span> <span class="p">:</span> <span class="n">MonoBehaviour</span>
<span class="p">{</span>
    <span class="k">private</span> <span class="n">Renderer</span> <span class="n">myRenderer</span><span class="p">;</span> 

    <span class="k">public</span> <span class="n">Color</span> <span class="n">touchColor</span><span class="p">;</span> <span class="c1">// м¶©лҸҢмӢң л°”лҖ” мғүмқ„ м°ёмЎ°н•  ліҖмҲҳ. publicмқҙлқј мң лӢҲнӢ°м—җм„ң м–ём ңл“ м§Җ мҲҳм • к°ҖлҠҘ</span>
    <span class="k">private</span> <span class="n">Color</span> <span class="n">originalColor</span><span class="p">;</span> <span class="c1">// мӣҗлһҳ мғүмқ„ м°ёмЎ°н•  ліҖмҲҳ. privateмқҙлқј мң лӢҲнӢ°м—җм„ң мҲҳм • л¶Ҳк°ҖлҠҘ</span>

    <span class="k">void</span> <span class="nf">Start</span><span class="p">()</span>
    <span class="p">{</span>
        <span class="n">myRenderer</span> <span class="p">=</span> <span class="n">GetComponent</span><span class="p">&lt;</span><span class="n">Renderer</span><span class="p">&gt;();</span> 
        <span class="n">originalColor</span> <span class="p">=</span> <span class="n">myRenderer</span><span class="p">.</span><span class="n">material</span><span class="p">.</span><span class="n">color</span><span class="p">;</span> <span class="c1">// Start()м•Ҳм—җ н•ҙмЈјлҜҖлЎңмҚЁ кІҢмһ„ мӢңмһ‘н•ҳмһҗл§Ҳмһҗ мӣҗлһҳмғүмқ„ к°Җм ёмҷҖ ліҙмЎҙ</span>
    <span class="p">}</span>

    <span class="k">void</span> <span class="nf">Update</span><span class="p">()</span>
    <span class="p">{</span>
        
    <span class="p">}</span>

    <span class="k">void</span> <span class="nf">OnTriggerEnter</span><span class="p">(</span><span class="n">Collider</span> <span class="n">other</span><span class="p">)</span>  <span class="c1">// EnterлҠ” м¶©лҸҢмқ„ н•ң мҲңк°„</span>
    <span class="p">{</span>
        <span class="k">if</span><span class="p">(</span><span class="n">other</span><span class="p">.</span><span class="n">tag</span> <span class="p">==</span> <span class="s">"EndPoint"</span><span class="p">)</span>  
        <span class="p">{</span>
            <span class="n">myRenderer</span><span class="p">.</span><span class="n">material</span><span class="p">.</span><span class="n">color</span> <span class="p">=</span> <span class="n">touchColor</span><span class="p">;</span> 
        <span class="p">}</span>
    <span class="p">}</span>

    <span class="k">void</span> <span class="nf">OnTriggerExit</span><span class="p">(</span><span class="n">Collider</span> <span class="n">other</span><span class="p">)</span>  <span class="c1">// ExitлҠ” л–јм–ҙм§ҖлҠ” мҲңк°„</span>
    <span class="p">{</span>
        <span class="k">if</span><span class="p">(</span><span class="n">other</span><span class="p">.</span><span class="n">tag</span> <span class="p">==</span> <span class="s">"EndPoint"</span><span class="p">)</span>  
        <span class="p">{</span>
            <span class="n">myRenderer</span><span class="p">.</span><span class="n">material</span><span class="p">.</span><span class="n">color</span> <span class="p">=</span> <span class="n">originalColor</span><span class="p">;</span> <span class="c1">// мӣҗлһҳ мғүк№”лЎң лҸҢлҰ¬кё° </span>
        <span class="p">}</span>
    <span class="p">}</span>

