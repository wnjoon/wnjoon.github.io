<h4 id="public-void-reload">public void Reload()</h4>

<div class="language-c# highlighter-rouge"><div class="highlight"><pre class="highlight"><code>    <span class="k">public</span> <span class="k">void</span> <span class="nf">Reload</span><span class="p">()</span>
    <span class="p">{</span>
        <span class="c1">// 재장전 입력 감지시 재장전</span>
