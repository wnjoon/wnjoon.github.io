    <span class="k">public</span> <span class="k">void</span> <span class="nf">PlaySFX</span><span class="p">(</span><span class="kt">string</span> <span class="n">p_sfxName</span><span class="p">)</span>
    <span class="p">{</span>
        <span class="k">for</span> <span class="p">(</span><span class="kt">int</span> <span class="n">i</span> <span class="p">=</span> <span class="m">0</span><span class="p">;</span> <span class="n">i</span> <span class="p">&lt;</span> <span class="n">sfx</span><span class="p">.</span><span class="n">Length</span><span class="p">;</span> <span class="n">i</span><span class="p">++)</span>
        <span class="p">{</span>
            <span class="k">if</span> <span class="p">(</span><span class="n">p_sfxName</span> <span class="p">==</span> <span class="n">sfx</span><span class="p">[</span><span class="n">i</span><span class="p">].</span><span class="n">name</span><span class="p">)</span>
            <span class="p">{</span>
                <span class="k">for</span> <span class="p">(</span><span class="kt">int</span> <span class="n">j</span> <span class="p">=</span> <span class="m">0</span><span class="p">;</span> <span class="n">j</span> <span class="p">&lt;</span> <span class="n">sfxPlayer</span><span class="p">.</span><span class="n">Length</span><span class="p">;</span> <span class="n">j</span><span class="p">++)</span>
                <span class="p">{</span>
                    <span class="c1">// SFXPlayerм—җм„ң мһ¬мғқ мӨ‘мқҙм§Җ м•ҠмқҖ Audio SourceлҘј л°ңкІ¬н–ҲлӢӨл©ҙ </span>
                    <span class="k">if</span> <span class="p">(!</span><span class="n">sfxPlayer</span><span class="p">[</span><span class="n">j</span><span class="p">].</span><span class="n">isPlaying</span><span class="p">)</span>
                    <span class="p">{</span>
                        <span class="n">sfxPlayer</span><span class="p">[</span><span class="n">j</span><span class="p">].</span><span class="n">clip</span> <span class="p">=</span> <span class="n">sfx</span><span class="p">[</span><span class="n">i</span><span class="p">].</span><span class="n">clip</span><span class="p">;</span>
                        <span class="n">sfxPlayer</span><span class="p">[</span><span class="n">j</span><span class="p">].</span><span class="nf">Play</span><span class="p">();</span>
                        <span class="k">return</span><span class="p">;</span>
                    <span class="p">}</span>
                <span class="p">}</span>
                <span class="n">Debug</span><span class="p">.</span><span class="nf">Log</span><span class="p">(</span><span class="s">"лӘЁл“  мҳӨл””мҳӨ н”Ңл Ҳмқҙм–ҙк°Җ мһ¬мғқмӨ‘мһ…лӢҲлӢӨ."</span><span class="p">);</span>
                <span class="k">return</span><span class="p">;</span>
            <span class="p">}</span>
        <span class="p">}</span>
        <span class="n">Debug</span><span class="p">.</span><span class="nf">Log</span><span class="p">(</span><span class="n">p_sfxName</span> <span class="p">+</span> <span class="s">" мқҙлҰ„мқҳ нҡЁкіјмқҢмқҙ м—ҶмҠөлӢҲлӢӨ."</span><span class="p">);</span>
        <span class="k">return</span><span class="p">;</span>
    <span class="p">}</span>
<span class="p">}</span>

</code></pre></div></div>

