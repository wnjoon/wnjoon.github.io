    <span class="p">[</span><span class="n">SerializeField</span><span class="p">]</span> <span class="n">Sound</span><span class="p">[]</span> <span class="n">sfx</span> <span class="p">=</span> <span class="k">null</span><span class="p">;</span>
    <span class="p">[</span><span class="n">SerializeField</span><span class="p">]</span> <span class="n">Sound</span><span class="p">[]</span> <span class="n">bgm</span> <span class="p">=</span> <span class="k">null</span><span class="p">;</span>

    <span class="p">[</span><span class="n">SerializeField</span><span class="p">]</span> <span class="n">AudioSource</span> <span class="n">bgmPlayer</span> <span class="p">=</span> <span class="k">null</span><span class="p">;</span>
    <span class="p">[</span><span class="n">SerializeField</span><span class="p">]</span> <span class="n">AudioSource</span><span class="p">[]</span> <span class="n">sfxPlayer</span> <span class="p">=</span> <span class="k">null</span><span class="p">;</span>

    <span class="k">private</span> <span class="k">void</span> <span class="nf">Start</span><span class="p">()</span>
