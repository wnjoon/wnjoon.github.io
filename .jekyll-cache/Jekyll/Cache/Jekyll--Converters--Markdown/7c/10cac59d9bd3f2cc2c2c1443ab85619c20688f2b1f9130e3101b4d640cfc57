    <span class="k">private</span> <span class="k">void</span> <span class="nf">Cancel</span><span class="p">()</span>
    <span class="p">{</span>
        <span class="k">if</span> <span class="p">(</span><span class="n">isPreviewActivated</span><span class="p">)</span>
