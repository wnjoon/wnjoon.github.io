        <span class="k">this</span><span class="p">.</span><span class="n">health</span> <span class="p">=</span> <span class="n">health</span><span class="p">;</span>  <span class="c1">// 체력</span>

        <span class="c1">// 내비메쉬 에이전트의 이동 속도 설정</span>
