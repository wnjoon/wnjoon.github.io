        <span class="n">agent</span><span class="p">.</span><span class="n">speed</span> <span class="p">=</span> <span class="n">patrolSpeed</span><span class="p">;</span> <span class="c1">// 위에서 변경된 patrolSpeed로 다시 적용</span>
