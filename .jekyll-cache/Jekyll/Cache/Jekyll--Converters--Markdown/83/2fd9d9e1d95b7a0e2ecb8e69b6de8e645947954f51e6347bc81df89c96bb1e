    <span class="p">[</span><span class="n">SerializeField</span><span class="p">]</span> <span class="k">private</span> <span class="n">Text</span> <span class="n">ammoText</span><span class="p">;</span>
    <span class="p">[</span><span class="n">SerializeField</span><span class="p">]</span> <span class="k">private</span> <span class="n">Text</span> <span class="n">waveText</span><span class="p">;</span>

    <span class="k">public</span> <span class="k">void</span> <span class="nf">UpdateAmmoText</span><span class="p">(</span><span class="kt">int</span> <span class="n">magAmmo</span><span class="p">,</span> <span class="kt">int</span> <span class="n">remainAmmo</span><span class="p">)</span>  <span class="c1">// 'ammoText' 남은 탄창 UI 갱신</span>
    <span class="p">{</span>
        <span class="n">ammoText</span><span class="p">.</span><span class="n">text</span> <span class="p">=</span> <span class="n">magAmmo</span> <span class="p">+</span> <span class="s">"/"</span> <span class="p">+</span> <span class="n">remainAmmo</span><span class="p">;</span>
