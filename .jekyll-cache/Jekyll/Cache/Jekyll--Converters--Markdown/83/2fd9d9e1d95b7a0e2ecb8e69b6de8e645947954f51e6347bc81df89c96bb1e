    <span class="p">{</span>
        <span class="n">waveText</span><span class="p">.</span><span class="n">text</span> <span class="p">=</span> <span class="s">"Wave : "</span> <span class="p">+</span> <span class="n">waves</span> <span class="p">+</span> <span class="s">"\nEnemy Left : "</span> <span class="p">+</span> <span class="n">count</span><span class="p">;</span>
