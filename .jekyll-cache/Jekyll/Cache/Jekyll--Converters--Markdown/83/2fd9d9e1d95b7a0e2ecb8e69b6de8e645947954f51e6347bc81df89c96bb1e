    <span class="k">public</span> <span class="k">void</span> <span class="nf">UpdateScoreText</span><span class="p">(</span><span class="kt">int</span> <span class="n">newScore</span><span class="p">)</span>  <span class="c1">// 'scoreText' 점수 UI 갱신</span>
    <span class="p">{</span>
