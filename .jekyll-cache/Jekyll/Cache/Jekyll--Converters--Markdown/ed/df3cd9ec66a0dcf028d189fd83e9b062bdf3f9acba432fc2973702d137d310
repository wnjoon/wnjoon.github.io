        <span class="k">if</span><span class="p">(</span><span class="n">item</span> <span class="p">!=</span> <span class="k">null</span> <span class="p">&amp;&amp;</span> <span class="n">Inventory</span><span class="p">.</span><span class="n">invectoryActivated</span><span class="p">)</span>
