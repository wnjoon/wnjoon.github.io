                <span class="nf">StartCoroutine</span><span class="p">(</span><span class="nf">AttackCoroutine</span><span class="p">(</span><span class="s">"Attack"</span><span class="p">,</span> <span class="n">currentCloseWeapon</span><span class="p">.</span><span class="n">attackDelayA</span><span class="p">,</span> <span class="n">currentCloseWeapon</span><span class="p">.</span><span class="n">attackDelayB</span><span class="p">,</span> <span class="n">currentCloseWeapon</span><span class="p">.</span><span class="n">attackDelay</span><span class="p">));</span>
